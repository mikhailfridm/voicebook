# Zadarma
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_SIP_LOGIN=
ZADARMA_SIP_PASSWORD=
ZADARMA_SIP_SERVER=

# Yandex Cloud (STT)
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=

# Booking provider: "yclients" or "iiko"
BOOKING_PROVIDER=yclients

# Yclients (beauty, barbershop, car wash)
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=

# iiko Cloud API (restaurants)
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
IIKO_TERMINAL_GROUP_ID=

# TTS Provider: "chatterbox", "fish", or "yandex"
TTS_PROVIDER=chatterbox

# Chatterbox TTS (self-hosted, MIT license)
CHATTERBOX_TTS_BASE_URL=http://chatterbox-tts:4123
CHATTERBOX_TTS_VOICE=default

# Fish Speech TTS (backup, not used)
# FISH_TTS_BASE_URL=http://fish-tts:8080
# FISH_TTS_REFERENCE_ID=

# LLM Provider: "vllm", "openai", or "yandexgpt"
LLM_PROVIDER=vllm

# vLLM (self-hosted Qwen2.5-14B fine-tuned)
VLLM_BASE_URL=http://vllm:8100/v1
VLLM_MODEL_NAME=voicebook

# OpenAI (optional, if using as LLM provider)
OPENAI_API_KEY=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
